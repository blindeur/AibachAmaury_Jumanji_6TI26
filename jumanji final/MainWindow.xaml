<Window x:Class="test_martye.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jumanji Plateau"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        Background="#1E472A"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <!-- Le Frame sert de conteneur de navigation :
             il affiche soit l'accueil, soit le menu de selection, soit la page de jeu. -->
        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden" />

        <!-- La musique tourne au niveau de la fenetre principale pour rester disponible
             quelle que soit la page actuellement affichee. -->
        <MediaElement x:Name="player"
                      Source="song/drum.mp3"
                      LoadedBehavior="Manual"
                      MediaEnded="player_MediaEnded" />

        <!-- Ce bouton reste toujours visible au-dessus des pages.
             Il permet au joueur d'activer ou de couper la musique a tout moment. -->
        <Button x:Name="ToggleSoundButton"
                Width="170"
                Height="48"
                Margin="0,20,20,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="10"
                Click="ToggleSoundButton_Click"
                Background="#E8D27C"
                Foreground="#203518"
                BorderThickness="0"
                FontSize="16"
                FontWeight="Bold"
                Cursor="Hand"
                ToolTip="Active ou coupe la musique du jeu" />
    </Grid>
</Window>
