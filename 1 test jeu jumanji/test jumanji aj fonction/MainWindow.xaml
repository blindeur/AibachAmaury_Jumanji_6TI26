<Window x:Class="test_jumanji_aj_fonction.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:test_jumanji_aj_fonction"
        mc:Ignorable="d"
          Background="DarkGreen"
        ResizeMode="NoResize"
        Title="Jumanji"
        Width="806"
        Height="732"
        WindowStartupLocation="CenterScreen">

    <Grid Name="grdMain">

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- TITRE -->
        <TextBlock Text="JUMANJI"
                   FontSize="50"
                   Foreground="Gold"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- PLATEAU -->
        <Grid Grid.Row="1" Grid.Column="0" Name="zonePlateau" Margin="5">
            <Grid.Background>
                <ImageBrush ImageSource="Images/plateau.png" Stretch="UniformToFill"/> 
            </Grid.Background>
        </Grid> 

        <!-- VOLET DROIT -->
        <StackPanel Grid.Row="1" Grid.Column="1">

            <Border Background="#FFB1B192" Padding="10">
                <StackPanel>

                    <TextBlock Text="Joueur" FontSize="20"/>
                    <TextBlock Name="lblJoueur" Text="Joueur 1" FontSize="20"/>

                    <Button Content="LANCER DÉ"
                            Width="160"
                            FontSize="24"
                            Margin="0,10"
                            Click="btnLancerDe_Click"/>

                    <TextBlock Text="Dé sorti :" FontSize="18"/>
                    <TextBlock Name="lblDe" FontSize="18"/>

                    <TextBlock Name="lblPosition"
                               FontSize="16"
                               Margin="0,10"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Window>

