<Page x:Class="test_martye.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#173926">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="20"
                Padding="12"
                Margin="0,0,18,0"
                BorderBrush="#80F3D17C"
                BorderThickness="2">
            <Grid x:Name="BoardGrid">
                <Grid.Background>
                    <ImageBrush ImageSource="Images/plateau.png" Stretch="UniformToFill" />
                </Grid.Background>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                CornerRadius="20"
                Padding="20"
                Background="#DDF2E9C6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Partie en cours"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#203518" />
                    <TextBlock x:Name="PlayerCountText"
                               Margin="0,6,0,0"
                               FontSize="16"
                               Foreground="#355627" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Padding="14"
                        CornerRadius="16"
                        Background="#FFF8EE">
                    <StackPanel>
                        <TextBlock Text="Tour actuel"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#203518" />
                        <TextBlock x:Name="CurrentPlayerText"
                                   Margin="0,8,0,0"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#203518" />
                        <TextBlock x:Name="DiceText"
                                   Margin="0,8,0,0"
                                   FontSize="18"
                                   Foreground="#355627" />
                        <TextBlock x:Name="StatusText"
                                   Margin="0,8,0,0"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Foreground="#355627" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        Padding="14"
                        CornerRadius="16"
                        Background="#FFF8EE">
                    <StackPanel>
                        <TextBlock Text="Derniere question"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#203518" />
                        <TextBlock x:Name="QuestionText"
                                   Margin="0,8,0,0"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Foreground="#355627"
                                   Text="Lancez le de pour faire parler la jungle." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,18,0,0"
                        Padding="14"
                        CornerRadius="16"
                        Background="#FFF8EE">
                    <StackPanel>
                        <TextBlock Text="Joueurs"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#203518" />
                        <StackPanel x:Name="PlayersPanel"
                                    Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="4"
                           Margin="0,18,0,0"
                           Text="Objectif: atteindre la derniere case du plateau."
                           FontSize="15"
                           TextWrapping="Wrap"
                           Foreground="#203518" />

                <StackPanel Grid.Row="5"
                            Margin="0,18,0,0">
                    <Button x:Name="RollDiceButton"
                            Height="58"
                            Click="RollDiceButton_Click"
                            Margin="0,0,0,12"
                            FontSize="22"
                            FontWeight="Bold"
                            Background="#E8D27C"
                            Foreground="#203518"
                            BorderThickness="0"
                            Cursor="Hand"
                            Content="Lancer le de" />

                    <Button x:Name="SaveAndQuitButton"
                            Height="54"
                            Click="SaveAndQuitButton_Click"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Background="#355627"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Content="Quitter et sauvegarder" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
